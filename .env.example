# =============================================================
# Sift — Single source of truth for all environment variables
# Copy this file to .env in the project root and fill in values
# =============================================================

# Database (Docker service name: postgres)
DATABASE_URL=postgresql+asyncpg://sift:siftpass@postgres:5432/sift

# Auth
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth (Login + Gmail)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Notion
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Token encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-encryption-key

# URLs
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:8001
ALLOWED_ORIGINS=["http://localhost:5174","http://localhost:3000","https://sift-app.loca.lt","https://sift-api.loca.lt"]

# App behaviour
FRESH_START_THRESHOLD_HOURS=18
SYNC_INTERVAL_MINUTES=30
